{
  "info": {
    "name": "Bookstore API",
    "description": "Collection for the Bookstore backend. Import into Postman, then:\n1. Set `baseUrl` (default http://localhost:3000/api)\n2. Run **Auth → Login** — the test script saves `token` automatically\n3. Use Admin endpoints with an admin-role account",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "bookId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "cartItemId", "value": "1" },
    { "key": "userId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dilovan Matini\",\n  \"email\": \"dilovan@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9647501112233\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dilovan@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dilovan Updated\",\n  \"phone\": \"9647501112299\"\n}"
            },
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "List Books",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/books?query=&category_id=&limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["books"],
              "query": [
                { "key": "query", "value": "" },
                { "key": "category_id", "value": "" },
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Recent Books",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/books/recent?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["books", "recent"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        },
        {
          "name": "Get Book",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/books/{{bookId}}"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"book_id\": 1,\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/cart/{{cartItemId}}"
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart/{{cartItemId}}"
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"Masike, Duhok, Iraq\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?status=",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [{ "key": "status", "value": "" }]
            }
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Favorites",
      "item": [
        {
          "name": "List Favorites",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/favorites"
          }
        },
        {
          "name": "Add Favorite",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"book_id\": 1\n}"
            },
            "url": "{{baseUrl}}/favorites"
          }
        },
        {
          "name": "Remove Favorite",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/favorites/{{bookId}}"
          }
        }
      ]
    },
    {
      "name": "Admin — Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/categories?query=",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "categories"],
              "query": [{ "key": "query", "value": "" }]
            }
          }
        },
        {
          "name": "Get Category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/categories/{{categoryId}}"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fiction\"\n}"
            },
            "url": "{{baseUrl}}/admin/categories"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Science Fiction\"\n}"
            },
            "url": "{{baseUrl}}/admin/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Admin — Books",
      "item": [
        {
          "name": "List Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/books?query=",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "books"],
              "query": [{ "key": "query", "value": "" }]
            }
          }
        },
        {
          "name": "Get Book",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/books/{{bookId}}"
          }
        },
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 1,\n  \"title\": \"The Great Novel\",\n  \"description\": \"A wonderful story\",\n  \"author\": \"A. Writer\",\n  \"isbn\": \"978-0000000001\",\n  \"published_at\": \"2024-01-15\",\n  \"price\": 19.99,\n  \"image\": null\n}"
            },
            "url": "{{baseUrl}}/admin/books"
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"The Great Novel (Revised)\",\n  \"price\": 21.99\n}"
            },
            "url": "{{baseUrl}}/admin/books/{{bookId}}"
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/books/{{bookId}}"
          }
        }
      ]
    },
    {
      "name": "Admin — Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/orders?query=&status=",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "orders"],
              "query": [
                { "key": "query", "value": "" },
                { "key": "status", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/orders/{{orderId}}"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": "{{baseUrl}}/admin/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Admin — Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/users?query=",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"],
              "query": [{ "key": "query", "value": "" }]
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9647501114455\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"9647501114477\"\n}"
            },
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Set Active Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": false\n}"
            },
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        }
      ]
    }
  ]
}
